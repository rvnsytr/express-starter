{
  "compilerOptions": {
    "target": "esnext",
    "jsx": "react-jsx",
    "module": "esnext",
    "paths": { "@/*": ["./src/*"] },
    "lib": ["esnext"],
    "types": ["node", "express"],
    "typeRoots": ["./node_modules/@types", "types.d.ts"],

    // Bundler mode
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    // "verbatimModuleSyntax": true,
    "noEmit": true,

    /* Linting */
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,

    "rootDir": "./src",
    "outDir": "./dist",

    // Other Outputs
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true
  },

  "include": ["types.d.ts", "**/*.ts", "eslint.config.js", "types.d.ts"],
  "exclude": ["node_modules"]
}
