meta {
  name: /api/storage
  type: http
  seq: 3
}

post {
  url: {{host}}/api/storage
  body: multipartForm
  auth: none
}

params:query {
  ~fileName: something
  ~url: true
}

headers {
  Origin: {{origin}}
}

body:multipart-form {
  file: @file(/home/ravensky/Pictures/WhatsApp Image 2025-11-06 at 8.31.43 AM.jpeg)
}

settings {
  encodeUrl: true
  timeout: 0
}
