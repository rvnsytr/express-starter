meta {
  name: /api/files
  type: http
  seq: 1
}

post {
  url: {{host}}/api/files
  body: multipartForm
  auth: none
}

params:query {
  ~fileName: something
  ~url: true
}

body:multipart-form {
  file: @file(/home/ravensky/Pictures/IMG-20240528-WA0022.jpg)
}

settings {
  encodeUrl: true
  timeout: 0
}
