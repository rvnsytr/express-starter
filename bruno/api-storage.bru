meta {
  name: /api/storage
  type: http
  seq: 9
}

post {
  url: {{host}}/api/storage?fileName=something
  body: multipartForm
  auth: none
}

params:query {
  fileName: something
  ~url: true
}

headers {
  Origin: {{origin}}
}

body:multipart-form {
  image: @file(/home/ravensky/Projects/purnaku-app/public/cover.png)
  ~something: Something
}

settings {
  encodeUrl: true
  timeout: 0
}
